---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllProyectoSlugs, getProyectoBySlug } from '../lib/sanity';
import { urlFor } from '../lib/imageUrl';

let proyectos: any[] = [];
try {
  const slugs = await getAllProyectoSlugs();
  if (slugs?.length) {
    const fetchedAll = await Promise.all(slugs.map(({ slug }) => getProyectoBySlug(slug)));
    proyectos = fetchedAll.filter(Boolean);
  }
} catch {}

function imgSrc(image: any, width = 800) {
  if (!image?.asset) return '';
  return urlFor(image).width(width).auto('format').url();
}
---

<BaseLayout
  title="Casa Materia — Real Estate Boutique"
  description="Propiedades de autor presentadas con criterio. Casa Materia es una agencia boutique de real estate que muestra la esencia de cada propiedad."
>
<style is:global>
  body { background: var(--blanco); }

  /* ── NAV ── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem clamp(1.5rem, 5vw, 4rem);
    transition: background 400ms var(--ease), border-color 400ms var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: rgba(42,40,37,0.86);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(200,187,168,0.12);
  }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 22px; letter-spacing: 0.01em; color: var(--crema); line-height: 1; }
  .nav-logo em { font-style: italic; color: var(--piedra); }
  .nav-cta {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--crema); border: 1px solid rgba(200,187,168,0.35); padding: 0.6rem 1.1rem;
    text-decoration: none; transition: background 240ms var(--ease);
  }
  .nav-cta:hover { background: var(--tierra); border-color: var(--tierra); }

  /* ── COVER ── */
  .cover {
    min-height: 100svh;
    background: var(--carbon);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: clamp(4rem, 10vh, 7rem) clamp(1.5rem, 5vw, 4rem);
    position: relative; overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(139,115,85,0.15) 0%, transparent 55%),
      radial-gradient(ellipse at 10% 90%, rgba(107,136,64,0.08) 0%, transparent 45%);
  }
  .cover-eyebrow {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--tierra); margin-bottom: 2rem; position: relative;
  }
  .cover-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(64px, 11vw, 120px); font-weight: 300; line-height: 0.9;
    letter-spacing: -0.02em; color: var(--crema); position: relative; margin-bottom: 1.5rem;
  }
  .cover-title em { font-style: italic; color: var(--piedra); }
  .cover-sub {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: clamp(17px, 2vw, 22px); color: rgba(200,187,168,0.5);
    position: relative; max-width: 40ch; line-height: 1.5;
  }
  .cover-rule { width: 0.5px; height: 60px; background: rgba(200,187,168,0.15); margin: 2.5rem 0; position: relative; }

  /* ── PROPERTIES GRID ── */
  .propiedades { padding: clamp(5rem, 12vh, 9rem) 0; }
  .prop-header { margin-bottom: clamp(3rem, 6vh, 5rem); display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1.5rem; }
  .prop-header h2 {
    font-family: 'Cormorant Garamond', serif; font-weight: 300;
    font-size: clamp(36px, 5vw, 60px); line-height: 1; letter-spacing: -0.01em; color: var(--carbon);
  }
  .prop-header h2 em { font-style: italic; color: var(--tierra); }
  .prop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .prop-card { display: block; text-decoration: none; color: inherit; }
  .prop-card:hover .prop-img img { transform: scale(1.03); }
  .prop-img { aspect-ratio: 4/3; overflow: hidden; position: relative; background: var(--crema); }
  .prop-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms var(--ease); }
  .prop-img-ph {
    width: 100%; height: 100%;
    background: linear-gradient(160deg, var(--carbon) 0%, #3a3630 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .prop-img-ph span { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(200,187,168,0.25); }
  .prop-info { padding: 1.4rem 0 0; }
  .prop-info .tag { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--tierra); margin-bottom: 0.6rem; }
  .prop-info h3 {
    font-family: 'Cormorant Garamond', serif; font-weight: 300;
    font-size: clamp(24px, 2.8vw, 32px); color: var(--carbon); line-height: 1.05; margin-bottom: 0.5rem;
  }
  .prop-info .precio { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 18px; color: var(--tierra); }

  /* ── EMPTY STATE ── */
  .empty {
    text-align: center; padding: clamp(4rem, 10vh, 7rem) 0;
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: clamp(22px, 3vw, 32px); color: rgba(42,40,37,0.3);
  }

  /* ── MANIFIESTO ── */
  .home-manifesto { background: var(--carbon); color: var(--crema); padding: clamp(5rem, 12vh, 9rem) 0; }
  .home-manifesto .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
  .home-manifesto-text {
    font-family: 'Cormorant Garamond', serif; font-weight: 300;
    font-size: clamp(28px, 4vw, 52px); line-height: 1.4; letter-spacing: -0.01em;
    color: var(--crema); max-width: 820px;
  }
  .home-manifesto-text em { font-style: italic; color: var(--piedra); }
  .home-manifesto-sign { margin-top: 2rem; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: rgba(200,187,168,0.45); }

  /* ── FOOTER ── */
  .foot { background: var(--carbon-2); color: rgba(200,187,168,0.6); padding: clamp(2.5rem, 5vh, 4rem) 0 1.5rem; }
  .foot .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); display: flex; flex-direction: column; gap: 2rem; }
  .foot-logo { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 28px; color: var(--crema); }
  .foot-logo em { font-style: italic; color: var(--piedra); }
  .foot-bottom {
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(200,187,168,0.1); padding-top: 1.4rem;
    flex-wrap: wrap; gap: 0.5rem;
  }
  .foot-bottom span { font-size: 10.5px; letter-spacing: 0.06em; color: rgba(200,187,168,0.3); }
  .foot-bottom a { color: rgba(200,187,168,0.55); border-bottom: 1px solid rgba(213,132,142,0.45); }

  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
  .eyebrow { font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--tierra); font-weight: 400; }
</style>

<nav class="nav" id="mainNav">
  <a href="/" class="nav-logo">Casa <em>Materia</em></a>
</nav>

<!-- COVER -->
<header class="cover">
  <div class="cover-eyebrow">Real Estate Boutique</div>
  <h1 class="cover-title">Casa<br><em>Materia</em></h1>
  <div class="cover-rule"></div>
  <p class="cover-sub">Mostramos la esencia de cada propiedad — no solo fotos y ficha técnica.</p>
</header>

<!-- PROPIEDADES -->
<section class="propiedades">
  <div class="wrap">
    <div class="prop-header">
      <h2>Propiedades <em>actuales</em></h2>
    </div>
    {proyectos.length > 0 ? (
      <div class="prop-grid">
        {proyectos.map(p => (
          <a href={`/${p.slug?.current || ''}`} class="prop-card">
            <div class="prop-img">
              {p.heroImage ? (
                <img src={imgSrc(p.heroImage, 800)} alt={p.titulo} />
              ) : (
                <div class="prop-img-ph">
                  <span>{p.titulo}</span>
                </div>
              )}
            </div>
            <div class="prop-info">
              {p.ubicacion && <div class="tag">{p.ubicacion}</div>}
              <h3>{p.titulo}</h3>
              {p.precio && <div class="precio">{p.precio}</div>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty">
        <a href="/habitar-sin-fronteras" style="color:inherit;text-decoration:none;">
          Ver Habitar sin Fronteras →
        </a>
      </div>
    )}
  </div>
</section>

<!-- MANIFIESTO -->
<section class="home-manifesto">
  <div class="wrap">
    <p class="home-manifesto-text">
      Hay propiedades que se <em>listan</em> y hay propiedades que se <em>presentan</em>.<br>
      Cada casa tiene una esencia. Nuestra tarea es hacerla visible.
    </p>
    <p class="home-manifesto-sign">Casa Materia — Real Estate Boutique</p>
  </div>
</section>

<!-- FOOTER -->
<footer class="foot">
  <div class="wrap">
    <div class="foot-logo">Casa <em>Materia</em></div>
    <div class="foot-bottom">
      <span>© 2026 Casa Materia</span>
      <span><a href="https://sombrerorosa.com" target="_blank" rel="noopener">Sombrero Rosa</a></span>
    </div>
  </div>
</footer>

<script>
  const nav = document.getElementById('mainNav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
</BaseLayout>
