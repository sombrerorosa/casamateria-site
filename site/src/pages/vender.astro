---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllProyectoSlugs, getProyectoBySlug } from '../lib/sanity';
import { urlFor } from '../lib/imageUrl';

let proyectos: any[] = [];
try {
  const slugs = await getAllProyectoSlugs();
  if (slugs?.length) {
    const all = await Promise.all(slugs.map(({ slug }) => getProyectoBySlug(slug)));
    proyectos = all.filter(Boolean);
  }
} catch {}

function imgSrc(image: any, width = 900) {
  if (!image?.asset) return '';
  return urlFor(image).width(width).auto('format').url();
}
---

<BaseLayout
  title="Vender con nosotros — Casa Materia"
  description="Comercializamos propiedades premium como el lanzamiento de una marca. Concepto editorial, fotografía de autor y estrategia completa para el segmento que lo merece."
>
<style is:global>
  body { background: var(--cm-blanco); }

  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
  .s { padding: clamp(5rem, 12vh, 9rem) 0; position: relative; }
  .eyebrow { font-family: var(--cm-sans); font-weight: 400; font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--accent-text); }
  .eyebrow.on-dark { color: var(--cm-on-dark-soft); }
  .sec-title { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(36px, 5.5vw, 66px); line-height: 1.1; letter-spacing: -0.01em; color: var(--cm-ink); }
  .sec-title em { font-style: italic; color: var(--accent); }
  .sec-head { max-width: 760px; margin-bottom: clamp(2.5rem, 5vh, 4rem); }
  .sec-head .eyebrow { display: block; margin-bottom: 1.3rem; }
  .lead { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(21px, 2.6vw, 30px); line-height: 1.45; color: var(--cm-ink); }
  .lead em { font-style: italic; color: var(--accent); }
  .body-txt { font-size: 15px; line-height: 1.9; color: var(--cm-ink-body); max-width: 56ch; }
  .body-txt + .body-txt { margin-top: 1.1rem; }
  .body-txt strong { color: var(--cm-ink); font-weight: 500; }
  .rule { width: 48px; height: 1px; background: var(--accent); opacity: 0.5; }

  .btn { font-family: var(--cm-sans); font-weight: 400; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; text-decoration: none; display: inline-flex; align-items: center; gap: 0.6rem; padding: 1rem 1.5rem; cursor: pointer; transition: transform 240ms var(--ease), background 240ms var(--ease), color 240ms var(--ease), border-color 240ms var(--ease); border: 1px solid transparent; }
  .btn-solid { background: var(--accent); color: var(--cm-blanco); }
  .btn-solid:hover { transform: translateY(-2px); filter: brightness(1.06); }
  .btn-ghost { background: transparent; border-color: var(--cm-border); color: var(--cm-ink); }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent-text); }
  .btn-ghost.on-dark { border-color: var(--cm-border-dark); color: var(--cm-on-dark); }
  .btn-ghost.on-dark:hover { border-color: var(--cm-on-dark-soft); color: var(--cm-on-dark); }

  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; display: flex; align-items: center; justify-content: space-between; padding: 1.1rem clamp(1.5rem, 5vw, 4rem); transition: background 400ms var(--ease), border-color 400ms var(--ease), padding 400ms var(--ease); border-bottom: 1px solid transparent; }
  .nav.scrolled { background: rgba(42,40,37,0.85); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid var(--cm-border-dark); padding-top: 0.85rem; padding-bottom: 0.85rem; }
  .nav-logo { font-family: var(--cm-serif); font-weight: 300; font-size: 28px; letter-spacing: 0.01em; color: var(--cm-on-dark); line-height: 1; text-decoration: none; }
  .nav-logo em { font-style: italic; color: var(--cm-on-dark-soft); }
  .nav-right { display: flex; align-items: center; gap: clamp(1rem, 3vw, 2.4rem); }
  .nav-links { display: flex; gap: clamp(1rem, 2.5vw, 2.1rem); }
  .nav-links a { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(245,240,232,0.62); text-decoration: none; transition: color 240ms var(--ease); }
  .nav-links a:hover { color: var(--cm-on-dark); }
  .nav-cta { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cm-on-dark); text-decoration: none; border: 1px solid var(--cm-border-dark); padding: 0.6rem 1.1rem; border-radius: 100px; transition: background 240ms var(--ease), border-color 240ms var(--ease); white-space: nowrap; }
  .nav-cta:hover { background: var(--accent); border-color: var(--accent); }
  @media (max-width: 900px) { .nav-links { display: none; } }

  /* HERO */
  .hero { background: var(--cm-carbon); color: var(--cm-on-dark); min-height: 100vh; position: relative; overflow: hidden; display: flex; align-items: center; }
  .hero::after { content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 2; background: radial-gradient(ellipse at 20% 20%, rgba(139,115,85,0.18) 0%, transparent 55%); }
  .hero-bg { position: absolute; top: 0; left: 0; bottom: 0; width: 50%; z-index: 0; overflow: hidden; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.85); }
  .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(270deg, var(--cm-carbon) 0%, rgba(42,40,37,0.92) 25%, rgba(42,40,37,0.6) 60%, rgba(42,40,37,0.45) 100%); }
  .hero-copy { position: relative; z-index: 3; width: 100%; max-width: var(--maxw); margin: 0 auto; padding: clamp(7rem,13vh,9rem) clamp(1.5rem,5vw,4rem) clamp(5rem,11vh,7rem); display: flex; justify-content: flex-end; }
  .hero-copy-inner { max-width: 540px; }
  .hero-eyebrow { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.8rem; }
  .hero h1 { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(40px, 6.2vw, 82px); line-height: 1.04; letter-spacing: -0.02em; color: var(--cm-on-dark); margin-bottom: 0.5em; }
  .hero h1 em { font-style: italic; color: var(--cm-tierra); }
  .hero-sub { font-family: var(--cm-sans); font-weight: 400; font-size: clamp(16px, 1.9vw, 20px); color: rgba(200,187,168,0.78); max-width: 40ch; line-height: 1.35; margin-bottom: 2.2rem; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  @media (max-width: 820px) { .hero-bg { display: none; } .hero-copy { justify-content: flex-start; } .hero-copy-inner { max-width: 100%; } }

  /* ESENCIA */
  .esencia .wrap { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(2rem, 6vw, 5rem); align-items: start; }
  .esencia-aside .rule { margin-top: 1.4rem; }
  .insight { margin-top: clamp(2.5rem,5vh,3.5rem); border-top: 1px solid var(--cm-border); padding-top: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem,4vw,3rem); }
  .insight .q { font-family: var(--cm-serif); font-style: italic; font-weight: 300; font-size: clamp(20px,2.4vw,27px); line-height: 1.4; color: var(--cm-ink); }
  .insight .q em { color: var(--accent); }
  .insight .note { font-size: 13.5px; line-height: 1.8; color: var(--cm-ink-body); }
  @media (max-width: 820px) { .esencia .wrap { grid-template-columns: 1fr; gap: 1.6rem; } .insight { grid-template-columns: 1fr; gap: 1.4rem; } }

  /* MÉTODO */
  .metodo { background: var(--cm-crema); }
  .metodo .sec-head { margin-bottom: clamp(2rem,4vh,3rem); }
  .metodo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--cm-border); border: 1px solid var(--cm-border); }
  .step { background: var(--cm-crema); padding: clamp(1.8rem, 3vw, 2.6rem); display: flex; flex-direction: column; min-height: 240px; transition: background 320ms var(--ease); }
  .step:hover { background: var(--cm-blanco); }
  .step .n { font-family: var(--cm-serif); font-style: italic; font-size: clamp(34px,4vw,48px); font-weight: 300; color: var(--accent); line-height: 1; opacity: 0.55; }
  .step h3 { font-family: var(--cm-serif); font-weight: 400; font-size: clamp(22px,2.4vw,28px); color: var(--cm-ink); margin: 1.1rem 0 0.3rem; line-height: 1.1; }
  .step .meta { font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 0.9rem; }
  .step p { font-size: 13.5px; line-height: 1.8; color: var(--cm-ink-body); margin-top: auto; }
  @media (max-width: 860px) { .metodo-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .metodo-grid { grid-template-columns: 1fr; } }

  /* PROPIEDADES */
  .props .sec-head { margin-bottom: clamp(2rem,4vh,3rem); }
  .props-grid { display: grid; grid-template-columns: 1.55fr 1fr; gap: 1.4rem; }
  .prop-card { display: flex; flex-direction: column; text-decoration: none; border: 1px solid var(--cm-border); background: var(--cm-blanco); overflow: hidden; border-radius: 2px; transition: transform 360ms var(--ease), box-shadow 360ms var(--ease); color: inherit; }
  .prop-card:hover { transform: translateY(-4px); box-shadow: 0 24px 48px rgba(42,40,37,0.10); }
  .prop-card .ph { position: relative; aspect-ratio: 16/10; overflow: hidden; background: var(--cm-carbon); }
  .prop-card .ph img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms var(--ease); }
  .prop-card:hover .ph img { transform: scale(1.04); }
  .prop-card .ph-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(160deg, var(--cm-carbon) 0%, #3a3630 100%); }
  .prop-card .ph-ph span { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(200,187,168,0.2); }
  .prop-status { position: absolute; top: 1rem; left: 1rem; z-index: 3; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; background: var(--cm-carbon); color: var(--cm-on-dark); padding: 5px 11px; }
  .prop-status.verde { background: var(--cm-verde); }
  .prop-body { padding: clamp(1.6rem,3vw,2.2rem); display: flex; flex-direction: column; flex: 1; }
  .prop-eyebrow { font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 0.9rem; }
  .prop-name { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(28px,3.6vw,44px); line-height: 1.05; color: var(--cm-ink); letter-spacing: -0.01em; }
  .prop-name em { font-style: italic; color: var(--accent); }
  .prop-desc { font-size: 14px; line-height: 1.75; color: var(--cm-ink-body); margin: 1rem 0 1.4rem; max-width: 46ch; }
  .prop-foot { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-top: auto; border-top: 1px solid var(--cm-border); padding-top: 1.1rem; flex-wrap: wrap; }
  .prop-specs { font-size: 12.5px; color: var(--cm-ink-body); }
  .prop-price { font-family: var(--cm-serif); font-size: clamp(20px,2.4vw,26px); color: var(--cm-ink); }
  .prop-link { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-text); display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.2rem; transition: gap 240ms var(--ease); }
  .prop-card:hover .prop-link { gap: 0.85rem; }
  .prop-soon { border: 1px dashed var(--cm-border); background: transparent; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; padding: clamp(1.8rem,3vw,2.4rem); min-height: 100%; border-radius: 2px; }
  .prop-soon .eyebrow { display: block; margin-bottom: 1.2rem; }
  .prop-soon .t { font-family: var(--cm-serif); font-style: italic; font-weight: 300; font-size: clamp(24px,3vw,34px); line-height: 1.15; color: var(--cm-ink); }
  .prop-soon p { font-size: 13px; line-height: 1.8; color: var(--cm-ink-body); margin-top: 1rem; max-width: 30ch; }
  @media (max-width: 820px) { .props-grid { grid-template-columns: 1fr; } }

  /* MANIFIESTO */
  .manifesto { background: var(--cm-carbon); color: var(--cm-on-dark); }
  .manifesto .wrap { display: grid; grid-template-columns: 0.4fr 1fr; gap: clamp(2rem, 6vw, 5rem); align-items: start; }
  .manifesto-text { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(26px, 3.5vw, 44px); line-height: 1.28; letter-spacing: -0.01em; color: var(--cm-on-dark); }
  .manifesto-text em { font-style: italic; color: var(--cm-on-dark-soft); }
  .manifesto-sign { margin-top: 2.6rem; font-family: var(--cm-serif); font-style: italic; font-size: 17px; color: rgba(200,187,168,0.5); }
  @media (max-width: 760px) { .manifesto .wrap { grid-template-columns: 1fr; gap: 1.6rem; } }

  /* DUENOS */
  .duenos .wrap { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem,6vw,5rem); align-items: start; }
  .value-stat { border-top: 1px solid var(--cm-border); padding-top: 1.4rem; margin-top: 2rem; }
  .value-stat .num { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(44px,6vw,72px); line-height: 1; color: var(--cm-verde); }
  .value-stat .lbl { font-size: 13px; color: var(--cm-ink-body); line-height: 1.7; margin-top: 0.8rem; max-width: 38ch; }
  .value-stat .lbl strong { color: var(--cm-ink); font-weight: 500; }
  .cond-list { display: flex; flex-direction: column; gap: 0; }
  .cond { display: grid; grid-template-columns: 150px 1fr; gap: 1.5rem; padding: 1.15rem 0; border-bottom: 1px solid var(--cm-border); align-items: baseline; }
  .cond:first-child { border-top: 1px solid var(--cm-border); }
  .cond .k { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-text); }
  .cond .v { font-size: 14px; line-height: 1.7; color: var(--cm-ink-body); }
  .cond .v strong { color: var(--cm-ink); font-weight: 500; }
  @media (max-width: 820px) { .duenos .wrap { grid-template-columns: 1fr; } .cond { grid-template-columns: 1fr; gap: 0.3rem; } }

  /* CONTACTO */
  .contacto { background: var(--cm-carbon); color: var(--cm-on-dark); }
  .contacto .wrap { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem,6vw,5rem); align-items: start; }
  .contacto h2 { font-family: var(--cm-serif); font-weight: 300; font-size: clamp(34px,5vw,60px); line-height: 1.1; color: var(--cm-on-dark); margin: 1.2rem 0; }
  .contacto h2 em { font-style: italic; color: var(--cm-on-dark-soft); }
  .contacto .blurb { font-size: 14px; line-height: 1.85; color: rgba(200,187,168,0.74); max-width: 42ch; }
  .contacto .meeting { margin-top: 2rem; padding-top: 1.6rem; border-top: 1px solid var(--cm-border-dark); }
  .contacto .meeting .k { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(200,187,168,0.45); }
  .contacto .meeting .v { font-family: var(--cm-serif); font-size: clamp(22px,3vw,30px); color: var(--cm-on-dark); margin-top: 0.5rem; line-height: 1.2; }
  .contacto .meeting .v em { font-style: italic; color: var(--cm-on-dark-soft); }
  .form { display: flex; flex-direction: column; gap: 1.1rem; }
  .field { display: flex; flex-direction: column; gap: 0.5rem; }
  .field label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(200,187,168,0.55); }
  .field input, .field select, .field textarea { font-family: var(--cm-sans); font-weight: 300; font-size: 15px; color: var(--cm-on-dark); background: rgba(245,240,232,0.04); border: 1px solid var(--cm-border-dark); border-radius: 2px; padding: 0.85rem 1rem; transition: border-color 240ms var(--ease), background 240ms var(--ease); width: 100%; }
  .field input::placeholder, .field textarea::placeholder { color: rgba(200,187,168,0.35); }
  .field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--accent); background: rgba(245,240,232,0.07); }
  .field select { appearance: none; cursor: pointer; color: var(--cm-on-dark); }
  .field select option { background: var(--cm-carbon); color: var(--cm-on-dark); }
  .field textarea { resize: vertical; min-height: 90px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  .submit { font-family: var(--cm-sans); font-weight: 400; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cm-blanco); background: var(--accent); border: none; border-radius: 2px; padding: 1.05rem 1.4rem; cursor: pointer; transition: transform 240ms var(--ease), filter 240ms var(--ease); margin-top: 0.4rem; display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem; }
  .submit:hover { filter: brightness(1.08); transform: translateY(-2px); }
  .form-success { border: 1px solid var(--cm-border-dark); border-radius: 2px; padding: clamp(2rem,4vw,3rem); text-align: center; display: none; }
  .form-success.show { display: block; animation: fadein 500ms var(--ease); }
  .form-success .check { font-family: var(--cm-serif); font-style: italic; font-size: clamp(26px,3.5vw,38px); color: var(--cm-on-dark-soft); line-height: 1.2; }
  .form-success p { font-size: 13.5px; color: rgba(200,187,168,0.65); margin-top: 1rem; line-height: 1.7; }
  @keyframes fadein { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  @media (max-width: 820px) { .contacto .wrap { grid-template-columns: 1fr; } }
  @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } }

  /* FOOTER */
  .foot { background: var(--cm-carbon-deep); color: rgba(200,187,168,0.6); padding: clamp(3rem,6vh,4.5rem) 0 2rem; }
  .foot .wrap { display: flex; flex-direction: column; gap: 2.5rem; }
  .foot-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 2rem; }
  .foot-logo { font-family: var(--cm-serif); font-weight: 300; font-size: 34px; color: var(--cm-on-dark); line-height: 0.95; }
  .foot-logo em { font-style: italic; color: var(--cm-on-dark-soft); }
  .foot-tagline { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(200,187,168,0.4); margin-top: 0.9rem; }
  .foot-cols { display: flex; gap: clamp(2rem,6vw,5rem); flex-wrap: wrap; }
  .foot-col .h { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cm-on-dark-soft); margin-bottom: 0.9rem; opacity: 0.7; }
  .foot-col a, .foot-col p { display: block; font-size: 13px; color: rgba(200,187,168,0.65); text-decoration: none; line-height: 1.95; }
  .foot-col a:hover { color: var(--cm-on-dark); }
  .foot-bottom { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(200,187,168,0.1); padding-top: 1.6rem; flex-wrap: wrap; gap: 0.6rem; }
  .foot-bottom span { font-size: 10.5px; letter-spacing: 0.06em; color: rgba(200,187,168,0.3); }
  .foot-support { font-size: 10.5px; letter-spacing: 0.06em; color: rgba(200,187,168,0.42); }
  .foot-support a { color: var(--cm-rosa); text-decoration: none; border-bottom: 1px solid rgba(213,132,142,0.4); transition: color 240ms var(--ease); }
  .foot-support a:hover { color: #e0a0a8; }

  /* REVEAL */
  [data-reveal] { opacity: 0; transform: translateY(26px); transition: opacity var(--reveal-dur) var(--ease), transform var(--reveal-dur) var(--ease); }
  [data-reveal].in { opacity: 1; transform: none; }
  [data-reveal][data-delay="1"] { transition-delay: 90ms; }
  [data-reveal][data-delay="2"] { transition-delay: 180ms; }
  [data-reveal][data-delay="3"] { transition-delay: 270ms; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } [data-reveal] { opacity: 1; transform: none; transition: none; } }
</style>

<!-- NAV -->
<nav class="nav" id="nav">
  <a href="/" class="nav-logo">Casa <em>Materia</em></a>
  <div class="nav-right">
    <div class="nav-links">
      <a href="#esencia">Quiénes somos</a>
      <a href="#metodo">El método</a>
      <a href="#propiedades">Propiedades</a>
      <a href="#propietarios">Propietarios</a>
    </div>
    <a href="#contacto" class="nav-cta">Reunión sin compromiso</a>
  </div>
</nav>

<!-- HERO -->
<header class="hero" id="top">
  <div class="hero-bg">
    <img src="/hero-bg.jpg" alt="Casa Materia — propiedad de autor" />
  </div>
  <div class="hero-copy">
    <div class="hero-copy-inner">
      <div class="hero-eyebrow">
        <span class="eyebrow on-dark">Real Estate Boutique</span>
        <span class="rule" style="background:var(--cm-on-dark-soft);opacity:0.4;display:inline-block;width:48px;height:1px"></span>
      </div>
      <h1>No somos<br>inmobiliarios.<br><em>Somos lo que<br>pasa antes.</em></h1>
      <p class="hero-sub">Comercializamos propiedades premium como el lanzamiento de una marca — concepto, narrativa y deseo, antes de que el comprador vea el precio.</p>
      <div class="hero-actions">
        <a href="#contacto" class="btn btn-solid">Vender con nosotros →</a>
        <a href="#metodo" class="btn btn-ghost on-dark">Cómo trabajamos</a>
      </div>
    </div>
  </div>
</header>

<!-- ESENCIA -->
<section class="s esencia" id="esencia">
  <div class="wrap">
    <div class="esencia-aside" data-reveal="">
      <span class="eyebrow">01 · Quiénes somos</span>
      <h2 class="sec-title" style="margin-top:1.3rem">El mercado publica fichas. <em>Nosotros contamos historias.</em></h2>
      <div class="rule"></div>
    </div>
    <div data-reveal="" data-delay="1">
