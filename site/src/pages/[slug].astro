<script>
(function () {
  // Nav scroll
  const nav = document.getElementById('mainNav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Reveal on scroll
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(en => {
        if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    reveals.forEach(r => io.observe(r));
  } else {
    reveals.forEach(r => r.classList.add('in'));
  }

  // Form
  const form = document.getElementById('visitaForm') as HTMLFormElement | null;
  const successEl = document.getElementById('visitaSuccess');
  const submitBtn = document.getElementById('visitaSubmit') as HTMLButtonElement | null;
  if (!form || !successEl || !submitBtn) return;

  const emailRx = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const phoneRx = /^[\+]?[\d\s\-\(\)]{7,20}$/;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nombreEl = form.querySelector('#nombre') as HTMLInputElement;
    const telEl    = form.querySelector('#tel') as HTMLInputElement;
    const emailEl  = form.querySelector('#email') as HTMLInputElement;
    const momentoEl = form.querySelector('#momento') as HTMLSelectElement;
    const msgEl    = form.querySelector('#msg') as HTMLTextAreaElement;

    let valid = true;
    [nombreEl, telEl, emailEl].forEach(el => {
      if (!el.value.trim()) { el.style.borderColor = '#A6604A'; valid = false; }
      else el.style.borderColor = '';
    });
    if (emailEl.value && !emailRx.test(emailEl.value)) { emailEl.style.borderColor = '#A6604A'; valid = false; }
    if (telEl.value && !phoneRx.test(telEl.value)) { telEl.style.borderColor = '#A6604A'; valid = false; }
    if (!valid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    const projectName = form.dataset.project || document.title;
    const mensajeCompleto = [
      `Propiedad: ${projectName}`,
      `Momento: ${momentoEl.value}`,
      msgEl.value.trim() ? `Mensaje: ${msgEl.value.trim()}` : null,
    ].filter(Boolean).join('\n');

    const PORTAL_ID = '49258509';
    const FORM_ID = form.dataset.formId;

    if (!FORM_ID) {
      // Form ID not configured — show success for testing
      form.style.display = 'none';
      successEl.classList.add('show');
      return;
    }

    try {
      const res = await fetch(
        `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_ID}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fields: [
              { name: 'firstname', value: nombreEl.value.trim() },
              { name: 'email', value: emailEl.value.trim() },
              { name: 'hs_whatsapp_phone_number', value: telEl.value.trim() },
              { name: 'message', value: mensajeCompleto },
            ],
            context: { pageUri: window.location.href, pageName: document.title },
          }),
        }
      );

      if (res.ok) {
        form.style.display = 'none';
        successEl.classList.add('show');
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Solicitar visita privada →';
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Solicitar visita privada →';
    }
  });
})();

// ── Lightbox ──
(function () {
  const lb       = document.getElementById('lb');
  const lbImg    = document.getElementById('lbImg') as HTMLImageElement;
  const lbVideo  = document.getElementById('lbVideo') as HTMLVideoElement;
  const lbCounter = document.getElementById('lbCounter');
  const lbClose  = document.getElementById('lbClose');
  const lbPrev   = document.getElementById('lbPrev');
  const lbNext   = document.getElementById('lbNext');
  if (!lb || !lbImg || !lbVideo) return;

  type LbItem = { src: string; type: string };
  const groups: Record<string, LbItem[]> = {};
  document.querySelectorAll<HTMLElement>('.lb-trigger').forEach(el => {
    const g = el.dataset.group || 'default';
    if (!groups[g]) groups[g] = [];
    groups[g].push({ src: el.dataset.src || '', type: el.dataset.type || 'image' });
  });

  let currentGroup: LbItem[] = [];
  let currentIdx = 0;

  function showItem(idx: number) {
    currentIdx = (idx + currentGroup.length) % currentGroup.length;
    const item = currentGroup[currentIdx];
    if (item.type === 'video') {
      lbImg.style.display = 'none';
      lbVideo.style.display = '';
      lbVideo.src = item.src;
      lbVideo.load();
    } else {
      lbVideo.pause(); lbVideo.src = '';
      lbVideo.style.display = 'none';
      lbImg.style.display = '';
      lbImg.src = item.src;
    }
    if (lbCounter) lbCounter.textContent = `${currentIdx + 1} / ${currentGroup.length}`;
  }

  function open(group: string, idx: number) {
    currentGroup = groups[group] || [];
    if (!currentGroup.length) return;
    showItem(idx);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
    lb.focus();
  }

  function close() {
    lb.classList.remove('open');
    lbVideo.pause(); lbVideo.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLElement>('.lb-trigger').forEach((el, _, all) => {
    el.addEventListener('click', () => {
      const g = el.dataset.group || 'default';
      const groupEls = Array.from(all).filter(e => e.dataset.group === g);
      const idx = groupEls.indexOf(el);
      open(g, idx);
    });
  });

  lbClose?.addEventListener('click', close);
  lbPrev?.addEventListener('click', () => showItem(currentIdx - 1));
  lbNext?.addEventListener('click', () => showItem(currentIdx + 1));

  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') showItem(currentIdx - 1);
    if (e.key === 'ArrowRight') showItem(currentIdx + 1);
  });
})();

// ── Mapa de ubicación (Leaflet + CartoDB Positron) ──
(function () {
  const mapEl = document.getElementById('mapaUbicacion');
  if (!mapEl) return;

  const LAT = -35.03675;
  const LNG = -58.4353611;

  function initLeaflet() {
    const L = (window as any).L;
    const map = L.map('mapaUbicacion', {
      center: [LAT, LNG],
      zoom: 15,
      zoomControl: true,
      scrollWheelZoom: false,
      dragging: true,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> &copy; <a href="https://carto.com/" target="_blank">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    const icon = L.divIcon({
      className: '',
      html: '<div style="width:14px;height:14px;background:#8B7355;border-radius:50%;box-shadow:0 0 0 8px rgba(139,115,85,0.22);border:2px solid #fff;position:relative;z-index:1;"></div>' +
            '<div class="ubic-leaflet-lbl">La propiedad</div>',
      iconSize: [14, 14],
      iconAnchor: [7, 7],
      popupAnchor: [0, -20],
    });
    L.marker([LAT, LNG], { icon }).addTo(map);
  }

  // Load Leaflet CSS + JS dynamically
  const css = document.createElement('link');
  css.rel = 'stylesheet';
  css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
  document.head.appendChild(css);

  const js = document.createElement('script');
  js.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  js.onload = initLeaflet;
  document.head.appendChild(js);
})();
</script>

<!-- Lightbox -->
<div id="lb" class="lb" role="dialog" aria-modal="true">
  <button id="lbClose" class="lb-close" aria-label="Cerrar">✕</button>
  <div class="lb-media">
    <img id="lbImg" src="" alt="" style="display:none" />
    <video id="lbVideo" controls playsinline style="display:none"></video>
  </div>
  <button id="lbPrev" class="lb-btn" aria-label="Anterior">&#8249;</button>
  <button id="lbNext" class="lb-btn" aria-label="Siguiente">&#8250;</button>
  <div id="lbCounter" class="lb-counter"></div>
</div>

